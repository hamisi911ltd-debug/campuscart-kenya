# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ⚠️ REQUIRED: Admin Credentials
# Change these to secure values before deploying!
VITE_ADMIN_EMAIL=your-admin-email@example.com
VITE_ADMIN_PASSWORD=your-secure-password-here

# API Configuration
VITE_API_URL=http://localhost:3000/api

# Cloudflare R2 Configuration (for image uploads)
VITE_R2_PUBLIC_URL=https://pub-abc123.r2.dev
VITE_R2_BUCKET_NAME=campusmart-images
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ACCOUNT_ID=your_cloudflare_account_id

# Google OAuth Configuration (Optional)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Maps API (Optional)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Instructions:
# 1. Copy this file: cp .env.example .env.local
# 2. Update VITE_ADMIN_EMAIL and VITE_ADMIN_PASSWORD with secure values
# 3. Set up Cloudflare R2 and add R2 credentials (see CLOUDFLARE_R2_SETUP.md)
# 4. (Optional) Add Google OAuth Client ID for social login
# 5. (Optional) Add Google Maps API key for location features
# 6. Never commit .env.local to git (it's in .gitignore)
