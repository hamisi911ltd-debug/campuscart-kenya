# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ⚠️ REQUIRED: Admin Credentials
# Change these to secure values before deploying!
VITE_ADMIN_EMAIL=your-admin-email@example.com
VITE_ADMIN_PASSWORD=your-secure-password-here

# Google OAuth Configuration (Optional)
# Get these from Google Cloud Console: https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Maps API (Optional)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Instructions:
# 1. Copy this file: cp .env.example .env.local
# 2. Update VITE_ADMIN_EMAIL and VITE_ADMIN_PASSWORD with secure values
# 3. (Optional) Add Google OAuth Client ID for social login
# 4. (Optional) Add Google Maps API key for location features
# 5. Never commit .env.local to git (it's in .gitignore)
